{
    "name": "silverstripeltd/ai-seo",
    "description": "AI SEO module for Silverstripe CMS",
    "type": "silverstripe-vendormodule",
    "require": {
        "php": "^8.3",
        "silverstripe/framework": "^6.1",
        "silverstripe/cms": "^6",
        "silverstripe/admin": "^3",
        "symbiote/silverstripe-queuedjobs": "^6",
        "guzzlehttp/guzzle": "^7.0",
        "silverstripe/reports": "^6"
    },
    "require-dev": {
        "squizlabs/php_codesniffer": "^3",
        "phpunit/phpunit": "^11",
        "dnadesign/silverstripe-elemental": "^6",
        "silverstripe/behat-extension": "^6",
        "slevomat/coding-standard": "^8"
    },
    "autoload": {
        "psr-4": {
            "SilverstripeLtd\\AiSeo\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "SilverstripeLtd\\AiSeo\\Tests\\": "tests/php/"
        }
    },
    "scripts": {
        "lint": "phpcs src/ tests/php/",
        "lint-clean": "phpcbf src/ tests/php/"
    },
    "extra": {
        "expose": [
            "client/dist"
        ]
    },
    "config": {
        "allow-plugins": {
            "dealerdirect/phpcodesniffer-composer-installer": true
        }
    }
}
