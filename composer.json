{
    "name": "silverstripeltd/ai-metadata",
    "description": "AI metadata module for Silverstripe CMS",
    "type": "silverstripe-vendormodule",
    "require": {
        "php": "^8.3",
        "silverstripe/framework": "^6",
        "silverstripe/cms": "^6",
        "silverstripe/admin": "^3",
        "symbiote/silverstripe-queuedjobs": "^6",
        "guzzlehttp/guzzle": "^7.0",
        "silverstripe/reports": "^6"
    },
    "require-dev": {
        "silverstripe/standards": "^1",
        "squizlabs/php_codesniffer": "^3"
    },
    "autoload": {
        "psr-4": {
            "SilverstripeLtd\\AiMetadata\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "SilverstripeLtd\\AiMetadata\\Tests\\": "tests/php/"
        }
    },
    "scripts": {
        "lint": "phpcs src/ tests/php/",
        "lint-clean": "phpcbf src/ tests/php/"
    },
    "extra": {
        "expose": [
            "client/dist"
        ]
    },
    "config": {
        "allow-plugins": {
            "dealerdirect/phpcodesniffer-composer-installer": true
        }
    }
}
